    "@types/promise-retry": "^1.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typedoc": "~0.28.0",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "debug": "^4.4.0",
    "promise-retry": "^2.0.1"
  },
  "resolutions": {
